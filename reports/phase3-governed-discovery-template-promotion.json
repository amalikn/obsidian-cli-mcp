  ],
  "findings_addressed": [
    "Added server-side filtered governed discovery for search, search-with-context, outgoing links, and backlinks",
    "Added approved template type mappings and destination routing to the governed vault policy model",
    "Added governed create-from-template, review note, promotion candidate, curated note, and promotion log workflows",
    "Kept source notes immutable during review and promotion helper workflows",
    "Preserved Phase 2 fail-closed HTTP and pinned-vault guarantees while expanding governed usability"
  ],
  "findings_deferred": [
    "Broad folder listing, tag discovery, task discovery, base discovery, and template name-based discovery remain blocked in governed profiles",
    "Rename, move, delete, restore, task toggle, and runtime-state mutation remain blocked in governed profiles",
    "Governed template listing and reading remain blocked because the legacy tools are still name-based rather than policy-bounded",
    "HTTP is still controlled-use only and not claimed to be internet-safe"
  ],
  "discovery_changes": [
    "Re-enabled obsidian_search and obsidian_search_context in governed profiles through server-side filtered filesystem search constrained by discoveryAllowlist",
    "Replaced governed obsidian_list_links and obsidian_list_backlinks behavior with server-side filtered graph resolution so blocked targets and sources are not leaked",
    "Discovery operations now require allowed source paths and never reveal denylisted, hidden, or .obsidian paths"
  ],
  "template_creation_changes": [
    "Added templateAllowlist and templateTypes policy configuration with template type to template path and destination root mapping",
    "Added obsidian_create_note_from_template for deterministic template rendering with minimal variable substitution and no overwrite behavior",
    "Template workflows read only from approved template paths under 00_system/templates and write only to approved destination roots"
  ],
  "promotion_workflow_changes": [
    "Added obsidian_create_review_note and obsidian_create_promotion_candidate with deterministic destination derivation and source provenance",
    "Added obsidian_create_curated_note for curated note creation from approved templates and approved curated zones",
    "Added obsidian_log_promotion to create promotion log notes without mutating or moving the source note"
  ],
