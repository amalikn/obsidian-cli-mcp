# Path to the obsidian CLI binary
# Default: "obsidian" (assumes it's in PATH — standard install)
# Fallback: /Applications/Obsidian.app/Contents/MacOS/obsidian
OBSIDIAN_BIN=obsidian

# Default vault name (optional — Obsidian uses the active vault if omitted)
OBSIDIAN_VAULT=

# Transport mode: stdio (default) or http
MCP_TRANSPORT=stdio

# HTTP port (only used when MCP_TRANSPORT=http)
MCP_PORT=3000
