{
  "name": "@joemugen/obsidian-cli-mcp",
  "version": "0.1.0",
  "description": "MCP server for Obsidian CLI — semantic tools for vault management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "obsidian-cli-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "test": "vitest run",
